<Window x:Class="Dragonfly.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Dragonfly"
        Title="Dragonfly" Height="820" Width="1240" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        FontFamily="Segoe UI Variable Text, Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource Bg2}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,1,0">
            <DockPanel Margin="14,20">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6,0,0,24">
                    <Image x:Name="BrandIcon" Width="34" Height="30" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                    <TextBlock Text="Dragonfly" FontSize="21" FontWeight="Bold" Foreground="{StaticResource Accent}"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <TextBlock x:Name="VersionText" DockPanel.Dock="Bottom" Style="{StaticResource Faint}"
                           Margin="8,10"/>

                <StackPanel x:Name="NavPanel" DockPanel.Dock="Top"/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <ContentControl x:Name="ContentHost"/>
        </Grid>
    </Grid>
</Window>
