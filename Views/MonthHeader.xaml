<UserControl x:Class="Dragonfly.Views.MonthHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="4" Padding="3">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PrevBtn" Content="‹" Width="32" Height="30" FontSize="18" Cursor="Hand"
                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextDim}" Click="Prev_Click"/>
                <TextBlock x:Name="MonthLabel" MinWidth="150" TextAlignment="Center" VerticalAlignment="Center"
                           FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                <Button x:Name="NextBtn" Content="›" Width="32" Height="30" FontSize="18" Cursor="Hand"
                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextDim}" Click="Next_Click"/>
            </StackPanel>
        </Border>
        <Button x:Name="TodayBtn" Style="{StaticResource BtnSm}" Content="Back to today" Margin="8,0,0,0" Click="Today_Click"/>
        <Border x:Name="CurrentChip" Background="{StaticResource AccentDim}" CornerRadius="3" Padding="8,4" Margin="8,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="Current month" Foreground="{StaticResource Accent}" FontSize="12" FontWeight="SemiBold"/>
        </Border>
    </StackPanel>
</UserControl>
