<UserControl x:Class="Dragonfly.Views.PendingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:Dragonfly.Views">
    <Grid Margin="32,26,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,22">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <v:MonthHeader x:Name="Header" VerticalAlignment="Center"/>
                <Button x:Name="AddBtn" Style="{StaticResource BtnPrimary}" Content="+ Add pending" Margin="12,0,0,0" Click="Add_Click"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Pending" Style="{StaticResource H1}"/>
                <TextBlock Text="Expected deposits &amp; withdrawals — exact date or amount can be fuzzy." Style="{StaticResource Sub}" Margin="0,3,0,0"/>
            </StackPanel>
        </DockPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,20,24">
            <StackPanel x:Name="Body"/>
        </ScrollViewer>
    </Grid>
</UserControl>
